generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Country {
  US
  CA
  RW
}

enum Currency {
  USD
  CAD
  RWF
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  PENDING
  POSTED
  VOID
}

enum ConsentType {
  PAD_MANDATE
  PAD_WAIVER
}

model Organization {
  id               String   @id @default(uuid())
  legal_name       String
  country          Country
  tax_id_encrypted String?  @db.Text
  pad_waiver_active Boolean @default(false)
  created_at       DateTime @default(now())

  users           User[]
  ledgers         Ledger[]
  consent_records ConsentRecord[]
}

model User {
  id            String   @id @default(uuid())
  org_id        String
  email         String   @unique
  password_hash String
  role          String

  organization Organization @relation(fields: [org_id], references: [id])
}

model Ledger {
  id       String   @id @default(uuid())
  org_id   String
  currency Currency
  name     String

  organization  Organization   @relation(fields: [org_id], references: [id])
  accounts      Account[]
  journal_entries JournalEntry[]
}

model Account {
  id        String      @id @default(uuid())
  ledger_id String
  name      String
  type      AccountType
  code      Int
  is_system Boolean     @default(false)

  ledger   Ledger   @relation(fields: [ledger_id], references: [id])
  postings Posting[]
}

model JournalEntry {
  id                 String             @id @default(uuid())
  ledger_id          String
  posted_at          DateTime?
  description        String
  external_reference String?            @db.Text
  status             JournalEntryStatus
  idempotency_key    String             @unique
  created_at         DateTime           @default(now())

  ledger   Ledger    @relation(fields: [ledger_id], references: [id])
  postings Posting[]

  @@index([external_reference])
}

model Posting {
  id               String @id @default(uuid())
  journal_entry_id String
  account_id       String
  amount           BigInt

  journal_entry JournalEntry @relation(fields: [journal_entry_id], references: [id])
  account       Account      @relation(fields: [account_id], references: [id])
}

model ConsentRecord {
  id                String     @id @default(uuid())
  org_id            String
  consent_type      ConsentType
  text_version_hash String
  ip_address        String
  user_agent        String
  accepted_at       DateTime   @default(now())

  organization Organization @relation(fields: [org_id], references: [id])
}
