# Clover Books API - Environment Configuration
# Copy this file to .env and update values as needed

# ============================================================================
# SECURITY - Required for Production
# ============================================================================

# JWT Secret for signing authentication tokens
# IMPORTANT: Generate a strong random secret for production (at least 32 chars)
# Example: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-at-least-32-chars

# Environment: development | production
# When set to "production", JWT_SECRET is REQUIRED
RUST_ENV=development

# ============================================================================
# CORS Configuration
# ============================================================================

# Comma-separated list of allowed frontend origins
# Example: http://localhost:5173,https://app.yoursite.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ============================================================================
# Database
# ============================================================================

# SQLite database path (defaults to legacy/db/db.sqlite3)
# DATABASE_URL=sqlite:../legacy/db/db.sqlite3

# ============================================================================
# Google OAuth (Optional)
# ============================================================================

# Get these from Google Cloud Console: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# ============================================================================
# Companion Autonomy Engine (CAE)
# ============================================================================

CAE_SCHEMA_AUTOINIT=0
ENGINE_BUDGET_TOKENS_PER_DAY=100000
ENGINE_BUDGET_TOOL_CALLS_PER_DAY=500
ENGINE_BUDGET_RUNS_PER_DAY=200
ENGINE_APPROVAL_AMOUNT_THRESHOLD=1000
ENGINE_VELOCITY_THRESHOLD=50
ENGINE_SNAPSHOT_STALE_MINUTES=15
ENGINE_ALLOWLIST_DOMAINS=
ENGINE_LLM_ALLOWED_MODELS=
LLM_MODE=mock
TOOL_MODE=mock
