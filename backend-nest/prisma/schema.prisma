generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentProvider {
  STRIPE
  FLUTTERWAVE
}

enum PaymentIntentStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum ProcessedEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

enum LedgerEntryStatus {
  POSTED
}

model PaymentIntent {
  id                String              @id @default(uuid())
  provider          PaymentProvider
  providerReference String?
  amount            BigInt
  currency          String
  status            PaymentIntentStatus @default(PENDING)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  receipts          PaymentReceipt[]
  ledgerEntry       LedgerEntry?

  @@index([provider, providerReference])
}

model PaymentReceipt {
  id              String          @id @default(uuid())
  paymentIntentId String
  provider        PaymentProvider
  providerEventId String
  createdAt       DateTime        @default(now())
  paymentIntent   PaymentIntent   @relation(fields: [paymentIntentId], references: [id])

  @@unique([provider, providerEventId])
}

model LedgerEntry {
  id              String            @id @default(uuid())
  paymentIntentId String            @unique
  status          LedgerEntryStatus @default(POSTED)
  createdAt       DateTime          @default(now())
  paymentIntent   PaymentIntent     @relation(fields: [paymentIntentId], references: [id])
  lines           LedgerLine[]
}

model LedgerLine {
  id        String      @id @default(uuid())
  entryId   String
  account   String
  amount    BigInt
  createdAt DateTime    @default(now())
  entry     LedgerEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model ProcessedEvent {
  id                  String              @id @default(uuid())
  provider            PaymentProvider
  eventId             String
  status              ProcessedEventStatus
  processingStartedAt DateTime?
  processedAt         DateTime?
  failedAt            DateTime?
  errorMessage        String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([provider, eventId])
  @@index([status, processingStartedAt])
}

model WebhookEvent {
  id         String          @id @default(uuid())
  provider   PaymentProvider
  eventId    String
  rawBody    Bytes
  headers    Json
  receivedAt DateTime        @default(now())
}
