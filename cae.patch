+        .and_then(|v| v.as_i64())
+        .unwrap_or(0);
+    let mode = payload
+        .get("mode")
+        .and_then(|v| v.as_str())
+        .unwrap_or("suggest_only");
+
+    Some(serde_json::json!({
+        "generated_at": snapshot.generated_at,
